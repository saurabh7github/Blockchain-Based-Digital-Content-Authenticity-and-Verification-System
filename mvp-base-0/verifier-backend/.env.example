# Copy this file to .env and fill in your values.
# Never commit the real .env to version control.

# --- Required ----------------------------------------------------------------
# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/docverify?retryWrites=true&w=majority

# --- AI Engine ---------------------------------------------------------------
# Select the AI engine: eden_ai (default) | reality_defender
AI_ENGINE=eden_ai

# Eden AI API key — https://app.edenai.run/user/settings#api (free tier: 100 calls/day)
# Leave blank to run in mock mode (safe for local dev).
AI_API_KEY=

# Eden AI provider sub-selection:
#   image  detection: winstonai | hive | sensity
#   text   detection: openai
#   video  detection: deepware
AI_PROVIDER=winstonai

# Reality Defender API key — https://realitydefender.com
# Only used when AI_ENGINE=reality_defender
REALITY_DEFENDER_API_KEY=

# --- AI Thresholds (0-100) ---------------------------------------------------
# Score above which content is BLOCKED. Per-type overrides the fallback.
AI_BLOCK_THRESHOLD=80
AI_THRESHOLD_IMAGE=80
AI_THRESHOLD_VIDEO=60
AI_THRESHOLD_TEXT=70

# --- IPFS / Pinata -----------------------------------------------------------
# Leave blank to skip IPFS upload ("ipfs_placeholder" is anchored on-chain instead).
# Get keys from https://app.pinata.cloud/keys
PINATA_API_KEY=
PINATA_SECRET_KEY=

# --- Server ------------------------------------------------------------------
PORT=5000

# --- JWT Authentication -------------------------------------------------------
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_in_production
ADMIN_USERNAME=admin
# REQUIRED in production — no default, server will refuse to start login endpoint.
ADMIN_PASSWORD=change_me_in_production
# How long issued tokens stay valid (e.g. 8h, 24h, 7d)
JWT_EXPIRES_IN=8h

# --- Hyperledger Fabric (optional) -------------------------------------------
# Set FABRIC_ENABLED=true to mount /api/fabric/* routes.
# Requires a running Fabric network (see fabric/scripts/start-network.sh).
FABRIC_ENABLED=false
# gRPC endpoint of the peer (host:port)
FABRIC_PEER_ENDPOINT=localhost:7051
# TLS SNI / host alias matching the peer's TLS certificate CN
FABRIC_PEER_HOST_ALIAS=peer0.org1.example.com
# MSP ID of the organisation submitting transactions
FABRIC_MSP_ID=Org1MSP
# Channel and chaincode names
FABRIC_CHANNEL=mychannel
FABRIC_CHAINCODE=docverifier
