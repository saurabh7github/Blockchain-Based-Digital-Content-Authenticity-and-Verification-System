# fabric/.env.mtls.example
#
# Mutual TLS (mTLS) Configuration for Fabric Components
# Copy to .env.local and update with your actual values
#
# This configuration enables:
# - TLS for all peer-orderer communication
# - Client certificate authentication (mutual TLS)
# - Encrypted communication between organizations
# - Certificate-based peer identity verification

# ============================================================================
# ORDERER mTLS CONFIGURATION
# ============================================================================

# Enable TLS for orderers
ORDERER_GENERAL_TLS_ENABLED=true

# Require client certificates for orderer connections (mutual TLS)
ORDERER_GENERAL_TLS_CLIENTAUTHREQUIRED=true

# Orderer TLS certificate paths (in container)
# These should be mounted from docker-compose.yml volumes
ORDERER_GENERAL_TLS_CERT_FILE=/etc/hyperledger/fabric/tls/server.crt
ORDERER_GENERAL_TLS_KEY_FILE=/etc/hyperledger/fabric/tls/server.key
ORDERER_GENERAL_TLS_ROOTCERT_FILE=/etc/hyperledger/fabric/tls/ca.crt
ORDERER_GENERAL_TLS_CLIENTCERT_FILE=/etc/hyperledger/fabric/tls/client.crt
ORDERER_GENERAL_TLS_CLIENTKEY_FILE=/etc/hyperledger/fabric/tls/client.key

# Orderer operations endpoint TLS (optional)
ORDERER_OPERATIONS_TLS_ENABLED=true
ORDERER_OPERATIONS_TLS_CERT_FILE=/etc/hyperledger/fabric/tls/server.crt
ORDERER_OPERATIONS_TLS_KEY_FILE=/etc/hyperledger/fabric/tls/server.key

# ============================================================================
# PEER mTLS CONFIGURATION
# ============================================================================

# Enable TLS for peers
CORE_PEER_TLS_ENABLED=true

# Require client certificates (mutual TLS) - only for orderer connections
# Set to true for peer-to-peer TLS, false to allow peer discovery without certs
CORE_PEER_TLS_CLIENTAUTHREQUIRED=false

# Peer TLS certificate paths (in container)
CORE_PEER_TLS_CERT_FILE=/etc/hyperledger/fabric/tls/server.crt
CORE_PEER_TLS_KEY_FILE=/etc/hyperledger/fabric/tls/server.key
CORE_PEER_TLS_ROOTCERT_FILE=/etc/hyperledger/fabric/tls/ca.crt

# For connection to orderers, peers need client certificates
CORE_PEER_TLS_CLIENTCERT_FILE=/etc/hyperledger/fabric/tls/client.crt
CORE_PEER_TLS_CLIENTKEY_FILE=/etc/hyperledger/fabric/tls/client.key

# Peer operations endpoint TLS (recommended)
CORE_OPERATIONS_TLS_ENABLED=true
CORE_OPERATIONS_TLS_CERT_FILE=/etc/hyperledger/fabric/tls/server.crt
CORE_OPERATIONS_TLS_KEY_FILE=/etc/hyperledger/fabric/tls/server.key

# ============================================================================
# CA mTLS CONFIGURATION (if using Fabric CA)
# ============================================================================

# Enable TLS for Fabric CA
FABRIC_CA_SERVER_TLS_ENABLED=true

# CA certificate paths
FABRIC_CA_SERVER_TLS_CERTFILE=/etc/hyperledger/fabric-ca/tls/server.crt
FABRIC_CA_SERVER_TLS_KEYFILE=/etc/hyperledger/fabric-ca/tls/server.key

# Certificate authority for CA client authentication
FABRIC_CA_SERVER_TLS_CLIENTAUTH_TYPE=RequireAndVerifyClientCert
FABRIC_CA_SERVER_TLS_CLIENTAUTH_CERTFILES=/etc/hyperledger/fabric-ca/tls/ca.crt

# ============================================================================
# BACKEND GATEWAY TLS CONFIGURATION
# ============================================================================

# Enable TLS when connecting to Fabric peers from backend
FABRIC_TLS_ENABLED=true

# Path to Fabric CA certificate (used to verify peer certificates)
FABRIC_CA_CERT_PATH=/app/fabric/tls/fabric-ca.crt

# Backend client certificate for peer connections
FABRIC_CLIENT_CERT_PATH=/app/fabric/tls/client.crt
FABRIC_CLIENT_KEY_PATH=/app/fabric/tls/client.key

# Whether to verify peer TLS certificates
# Set to true in production, false only for self-signed certs in dev
FABRIC_TLS_VERIFY=true

# ============================================================================
# AWS SECRETS MANAGER (for storing TLS certificates in production)
# ============================================================================

# AWS region for Secrets Manager
AWS_REGION=us-east-1

# AWS Secrets Manager secret names (optional override)
# By default, secrets are looked up as: docverifier/production/{secret_name}
# Override specific paths if needed:
# ORDERER_TLS_CERT_SECRET=docverifier/production/orderer-tls-cert
# PEER_TLS_KEY_SECRET=docverifier/production/peer-tls-key

# ============================================================================
# CERTIFICATE MANAGEMENT
# ============================================================================

# Certificate validity period (in days)
CERT_VALIDITY_DAYS=365

# Require certificate renewal before expiry (in days)
CERT_RENEWAL_THRESHOLD=30

# Enable automatic certificate rotation
AUTO_CERT_ROTATION=true

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================

# Enable TLS debug logging
FABRIC_LOGGING_SPEC=INFO
GRPC_TRACE=all
GRPC_VERBOSITY=DEBUG

# Log TLS handshake details
GODEBUG=mssl=3
