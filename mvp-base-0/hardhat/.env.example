# Copy to .env and fill in values. Never commit .env to version control.

# Private key of the Sepolia deployment wallet (WITHOUT the 0x prefix)
DEPLOYER_PRIVATE_KEY=

# Sepolia JSON-RPC endpoint (optional — falls back to publicnode.com)
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com

# Etherscan API key — required only if you want to verify source after deployment
# Get one at: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
